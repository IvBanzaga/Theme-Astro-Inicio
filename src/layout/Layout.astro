---
import Head from "@/components/sections/Head.astro"
import Theme from "@/components/Theme.astro"

// Definir el tipo de las props del Layout
interface Props {
	title: string
	description: string
	image?: string
}

const { title, description, image = "/astro-logo-light-gradient.svg" } = Astro.props
---

<!doctype html>
<html lang='es' data-theme='dark'>
	<Head title={title} description={description} image={image} />
	<body>
		<div id='background-mask' class='min-h-screen w-full'>
			<Theme />
			<slot />
		</div>
	</body>
</html>
