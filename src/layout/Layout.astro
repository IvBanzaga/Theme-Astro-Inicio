---
import Head from "@/components/sections/Head.astro"
import Footer from "@/components/sections/Footer.astro"
import Header from "@/components/sections/Header.astro"
import NavBar from "@/components/sections/NavBar.astro"

// Definir el tipo de las props del Layout
interface Props {
	title: string
	description: string
	image?: string
}

const { title, description, image = "/astro-logo-light-gradient.svg" } = Astro.props
---

<!doctype html>
<html lang="es" data-theme="dark">
	<Head title={title} description={description} image={image} />
	<body class="flex flex-col min-h-screen">
		<!--
      NavBar: se mantiene arriba de todo.
      body:
        - flex flex-col: organiza los elementos hijos en columna.
        - min-h-screen: asegura que el body ocupe al menos toda la altura de la ventana.
    -->
		<NavBar />

		<main class="flex-1 flex flex-col items-center justify-center">
			<!--
        main:
          - flex-1: hace que el contenido principal crezca para ocupar el espacio disponible.
          - flex flex-col: organiza el contenido en columna.
          - items-center: centra horizontalmente.
          - justify-center: centra verticalmente.
        Con esto, el contenido se mantiene centrado si es pequeño y empuja el footer al final si es más grande.
      -->
			<slot />
		</main>

		<!-- Footer se mantiene siempre al final, sin generar scroll extra innecesario -->
		<Footer />
	</body>
</html>
