---
// Importación usando el subpath recomendado
import Navigation from "@sofidevo/astro-dynamic-header/Header"
// Importación de tipos por separado para mejor rendimiento
import type { MenuItemType } from "@sofidevo/astro-dynamic-header"

// Tipado fuerte del menú usando MenuItemType
const menuItems: MenuItemType[] = [
	{
		link: "/",
		text: "Inicio",
	},
	{
		link: "#",
		text: "Categorías",
		submenu: [
			{ link: "/categoria/desarrollo-web", text: "Desarrollo Web" },
			{ link: "/categoria/javascript", text: "JavaScript" },
			{ link: "/categoria/astro", text: "Astro" },
			{ link: "/categoria/tutoriales", text: "Tutoriales" },
		],
	},
	{
		link: "#",
		text: "Demos",
		submenu: [
			{ link: "/demo-floating", text: "Header Floating" },
			{ link: "/", text: "Header Fullscreen" },
		],
	},
	{
		link: "#",
		text: "Recursos",
		submenu: [
			{ link: "/recursos/herramientas", text: "Herramientas" },
			{ link: "/recursos/bibliotecas", text: "Bibliotecas" },
			{ link: "/recursos/inspiracion", text: "Inspiración" },
		],
	},
	{ link: "/acerca-de", text: "Acerca de" },
	{ link: "/contacto", text: "Contacto" },
]
---

<div class='nav-container'>
	<Navigation
		headerType='floating'
		logoSrc='/favicon.png'
		logoAlt='dev'
		logoWidth='75px'
		homeUrl='/'
		menuItems={menuItems}
		backgroundColor='var(--header-background)'
		backdropBlur='var(--header-backdrop-blur)'
		zIndex={100}
	/>
</div>
