---
import Layout from "@/layout/Layout.astro"
---

<Layout title='Not Found 💫' description='Página no encontrada'>
	<div class='flex flex-col items-center justify-center min-h-screen'>
		<h1 class='text-3xl font-bold text-violet-700'>Página no encontrada</h1>
		<p class='text-lg text-gray-700'>Lo sentimos, la página que buscas no existe.</p>
		<button
			class='mt-4 bg-violet-500 text-white px-4 py-2 rounded hover:bg-violet-600'
			onclick="window.location.href='/'">
			Volver al inicio
		</button>
	</div>
</Layout>
