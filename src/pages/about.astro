---
import Layout from "@/layout/Layout.astro"
---

<Layout title='Acerca de' description='Información sobre el proyecto'>
	<div class='flex flex-col items-center justify-center min-h-screen'>
		<h1 class='text-3xl font-bold text-violet-700'>Acerca de Astro Minimal</h1>
		<p class='text-lg text-gray-700'>
			Esta es una página de ejemplo que muestra cómo usar Astro con Tailwind CSS. Explora
			el código para aprender más sobre la estructura del proyecto.
		</p>
		<button
			class='mt-4 bg-violet-500 text-white px-4 py-2 rounded hover:bg-violet-600'
			onclick="window.location.href='/'">
			Volver al inicio
		</button>
	</main>
</Layout>
