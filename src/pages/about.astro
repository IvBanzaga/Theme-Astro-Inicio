---
import Layout from "@/layout/Layout.astro"
---

<Layout title='Acerca de' description='Información sobre el proyecto'>
	<div class='flex flex-1 flex-col items-center justify-center'>
		<h1 class='text-3xl font-bold'>Acerca de Astro Minimal</h1>
		<p class='text-lg p-5 text-center'>
			Esta es una página de ejemplo que muestra cómo usar Astro con Tailwind CSS. Explora
			el código para aprender más sobre la estructura del proyecto.
		</p>
		<button
			class='button-primary'
			onclick="window.location.href='/'">
			Volver al inicio
		</button>
	</div>
</Layout>